{
  "sessionId": "example-session",
  "datasetPath": "./tiny-dataset.json",
  "outputDir": "../tmp/backtest-example",
  "audit": {
    "databasePath": "../tmp/backtest-example/audit.sqlite",
    "exportDir": "../tmp/backtest-example/audit"
  },
  "runtime": {
