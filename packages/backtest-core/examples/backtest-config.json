      "maxLosingStreak": 10,
      "rollingExpectancyMinTrades": 100,
      "minTopBookDepth": 1,
      "abnormalSpreadAbsolute": 0.1,
      "noTradeBeforeExpiryHours": 0.05
    },
    "paperFillConfig": {
      "minTouchesBeforeFill": 2,
      "queuePriorityDelayMs": 1000,
      "passiveParticipationRate": 0.5,
      "minPartialFillSize": 1
    }
